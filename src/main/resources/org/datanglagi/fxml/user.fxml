<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="640.0" prefWidth="360.0" style="-fx-background-color:#F8F5F2;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.datanglagi.controller.UserController">

    <VBox alignment="CENTER" prefHeight="170.0" prefWidth="360.0" spacing="8" style="-fx-background-color:#6E1418;">
        <children>
            <Label style="-fx-text-fill:#F3D5D5; -fx-font-size:13;" textFill="WHITE">
            <font>
               <Font name="Poppins SemiBold" size="18.0" />
            </font></Label>
         <Label text="Selamat Datang" textFill="WHITE">
            <font>
               <Font name="Poppins SemiBold Italic" size="18.0" />
            </font>
         </Label>
         <Label fx:id="lblUsername" layoutX="115.0" layoutY="48.0" text="Username" textFill="WHITE">
            <font>
               <Font name="Poppins SemiBold Italic" size="14.0" />
            </font>
         </Label>
        </children>
    </VBox>

    <VBox prefHeight="550.0" prefWidth="360.0" spacing="15" VBox.vgrow="ALWAYS">
        <padding><Insets left="18" right="18" top="15" /></padding>
        <children>
            <VBox spacing="10" style="-fx-background-color:white; -fx-background-radius:18; -fx-padding:15;">
                <Label style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#888888;" text="PENGATURAN" />
                <Button maxWidth="Infinity" prefHeight="42" style="-fx-background-color:#F8F5F2; -fx-background-radius:12; -fx-alignment:CENTER-LEFT;" text="Notifikasi" />
                <Button maxWidth="Infinity" prefHeight="42" style="-fx-background-color:#F8F5F2; -fx-background-radius:12; -fx-alignment:CENTER-LEFT;" text="Koneksi Pasangan" />
                <Button maxWidth="Infinity" prefHeight="42" style="-fx-background-color:#F8F5F2; -fx-background-radius:12; -fx-alignment:CENTER-LEFT;" text="Privasi dan Keamanan" />
            </VBox>

            <VBox spacing="10" style="-fx-background-color:white; -fx-background-radius:18; -fx-padding:15;">
                <Label style="-fx-font-size:14; -fx-font-weight:bold; -fx-text-fill:#888888;" text="LAINNYA" />
                <Button maxWidth="Infinity" prefHeight="42" style="-fx-background-color:#F8F5F2; -fx-background-radius:12; -fx-alignment:CENTER-LEFT;" text="Bantuan FAQ" />
                <Button maxWidth="Infinity" onMouseClicked="#handleTentang" prefHeight="42" style="-fx-background-color:#F8F5F2; -fx-background-radius:12; -fx-alignment:CENTER-LEFT;" text="Tentang DatangLagi" />
                <Button maxWidth="Infinity" onMouseClicked="#handleLogout" prefHeight="42" style="-fx-background-color:#9B1C1C; -fx-text-fill:white; -fx-background-radius:12;" text="Keluar" />
            </VBox>
        </children>
    </VBox>
</VBox>
